{
  "mcpServers": {
    "plane": {
      "type": "http",
      "url": "https://mcp.plane.so/http/api-key/mcp",
      "headers": {
        "Authorization": "Bearer plane_api_REPLACE_ME",
        "X-Workspace-slug": "autoorbit"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--browserUrl=http://127.0.0.1:9222"]
    }
  },
  "ebaySandbox": {
    "devPortalEmail": "REPLACE_ME@example.com",
    "devPortalPassword": "REPLACE_ME"
  }
}
